<?xml version="1.0"?>
<!--
  Differential-drive robot description with roboclaw_hardware ros2_control plugin.

  TCP connection to the RoboClaw via USR-K6 Ethernet-to-Serial converter.

  Override any argument at launch time:
    xacro roboclaw_diff_drive.urdf.xacro tcp_host:=10.0.0.5
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="roboclaw_diff_drive">

  <!-- ================================================================== -->
  <!-- Xacro arguments with sensible defaults for our robot               -->
  <!-- ================================================================== -->
  <xacro:arg name="tcp_host"              default="192.168.68.60"/>
  <xacro:arg name="tcp_port"              default="8234"/>
  <xacro:arg name="socket_timeout"        default="0.05"/>
  <xacro:arg name="address"               default="0x80"/>

  <xacro:arg name="wheel_radius"          default="0.2"/>
  <xacro:arg name="wheel_separation"      default="0.4"/>
  <xacro:arg name="encoder_counts_per_rev" default="1000"/>
  <xacro:arg name="gear_ratio"            default="16.0"/>

  <xacro:arg name="motion_strategy"       default="speed_accel"/>
  <xacro:arg name="default_acceleration"  default="2000"/>
  <xacro:arg name="buffer_depth"          default="4"/>

  <xacro:arg name="auto_home_on_startup"  default="false"/>
  <xacro:arg name="position_limits_enabled" default="false"/>

  <!-- ================================================================== -->
  <!-- Derived properties                                                 -->
  <!-- ================================================================== -->
  <xacro:property name="wheel_radius"     value="$(arg wheel_radius)"/>
  <xacro:property name="wheel_separation" value="$(arg wheel_separation)"/>
  <xacro:property name="wheel_width"      value="0.08"/>
  <xacro:property name="wheel_mass"       value="1.5"/>

  <xacro:property name="base_length"      value="0.50"/>
  <xacro:property name="base_width"       value="0.40"/>
  <xacro:property name="base_height"      value="0.15"/>
  <xacro:property name="base_mass"        value="15.0"/>

  <xacro:property name="caster_radius"    value="0.05"/>
  <xacro:property name="caster_mass"      value="0.3"/>

  <!-- ================================================================== -->
  <!-- Links                                                              -->
  <!-- ================================================================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <inertia
        ixx="${base_mass*(base_width*base_width+base_height*base_height)/12}"
        iyy="${base_mass*(base_length*base_length+base_height*base_height)/12}"
        izz="${base_mass*(base_length*base_length+base_width*base_width)/12}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}"
        iyy="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}"
        izz="${wheel_mass*wheel_radius*wheel_radius/2}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}"
        iyy="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}"
        izz="${wheel_mass*wheel_radius*wheel_radius/2}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <mass value="${caster_mass}"/>
      <inertia
        ixx="${2*caster_mass*caster_radius*caster_radius/5}"
        iyy="${2*caster_mass*caster_radius*caster_radius/5}"
        izz="${2*caster_mass*caster_radius*caster_radius/5}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!-- Joints                                                             -->
  <!-- ================================================================== -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_separation/2} 0" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_separation/2} 0" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${base_length/2-caster_radius} 0 ${-base_height/2-caster_radius}"/>
  </joint>

  <!-- ================================================================== -->
  <!-- ros2_control Hardware Interface                                     -->
  <!-- ================================================================== -->
  <ros2_control name="RoboClawSystem" type="system">
    <hardware>
      <plugin>roboclaw_hardware/RoboClawHardware</plugin>

      <param name="tcp_host">$(arg tcp_host)</param>
      <param name="tcp_port">$(arg tcp_port)</param>
      <param name="socket_timeout">$(arg socket_timeout)</param>
      <param name="address">$(arg address)</param>

      <param name="wheel_radius">$(arg wheel_radius)</param>
      <param name="wheel_separation">$(arg wheel_separation)</param>
      <param name="encoder_counts_per_rev">$(arg encoder_counts_per_rev)</param>
      <param name="gear_ratio">$(arg gear_ratio)</param>

      <param name="motion_strategy">$(arg motion_strategy)</param>
      <param name="default_acceleration">$(arg default_acceleration)</param>
      <param name="buffer_depth">$(arg buffer_depth)</param>

      <param name="auto_home_on_startup">$(arg auto_home_on_startup)</param>
      <param name="position_limits_enabled">$(arg position_limits_enabled)</param>
    </hardware>

    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <gpio name="diagnostics">
      <state_interface name="main_battery_v"/>
      <state_interface name="temperature_c"/>
      <state_interface name="error_status"/>
      <state_interface name="current_left_a"/>
      <state_interface name="current_right_a"/>
    </gpio>
  </ros2_control>

</robot>
